# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
LOG_LEVEL=info

# Database
DATABASE_URL=

# Application HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Google Calendar OAuth (optional)
# Leave false and omit the Google values to run Margin without Calendar.
GOOGLE_CALENDAR_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/calendar/callback

# AI provider
AI_API_KEY=
AI_MODEL=

# Encryption (generate with: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=
TOKEN_ENCRYPTION_KEY_VERSION=1

# Deterministic hackathon demo and preflight
# Use real Slack workspace and human user IDs. The publish command resolves the DM channel.
DEMO_WORKSPACE_ID=
DEMO_USER_ID=
# Optional provenance override before demo:publish resolves the actual DM.
# DEMO_SOURCE_CHANNEL_ID=
# Set at runtime to the exact value "${DEMO_WORKSPACE_ID}:${DEMO_USER_ID}".
# DEMO_CONFIRM_RESET=
# Required for demo resets unless NODE_ENV is explicitly development or test.
# DEMO_ALLOW_NON_DEVELOPMENT_RESET=true
# Optional when the app is reachable somewhere other than the local HTTP_PORT.
# PREFLIGHT_BASE_URL=http://127.0.0.1:3000

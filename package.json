{
  "name": "margin-slack-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A private, context-aware meeting micronote agent for Slack.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "migrate": "npm run build && node dist/storage/migrate.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.18.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
